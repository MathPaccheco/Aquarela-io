# ─────────────────────────────────────────────────────────────────────────────
# Aquarela.io — Environment Variables
# Copy this file to .env and fill in the values before running docker compose.
# NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Gateway ───────────────────────────────────────────────────────────────────
GATEWAY_PORT=3000
NODE_ENV=development

BATCH_FLUSH_INTERVAL_MS=5000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=aquarela
POSTGRES_USER=aquarela_user
POSTGRES_PASSWORD=change_me_in_env

# Full connection string consumed by both gateway and worker
DATABASE_URL=postgresql://aquarela_user:change_me_in_env@postgres:5432/aquarela

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=aquarela_user
RABBITMQ_PASSWORD=change_me_in_env
RABBITMQ_VHOST=/

# Full AMQP URL consumed by gateway and worker
RABBITMQ_URL=amqp://aquarela_user:change_me_in_env@rabbitmq:5672/

# RabbitMQ Management UI (port 15672) — uses the same credentials above
